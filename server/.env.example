NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:3000

# MONGO_URI=mongodb://127.0.0.1:27017/spakstrip
MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster-host>/?appName=Cluster0

ACCESS_TOKEN_SECRET=replace-with-32+chars-random-string
REFRESH_TOKEN_SECRET=replace-with-different-32+chars-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Recipient for pending-registration notification emails (Step 3 mailer).
SUPERADMIN_EMAIL=admin@example.com

# Superadmin panel (Step 5): password gate + secret for signing the admin-session cookie.
SUPERADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_SESSION_SECRET=replace-with-32+chars-random-string
