            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"TokenId\": \"{{TOKEN}}\",\n  \"EndUserIp\": \"{{END_USER_IP}}\",\n  \"BookingId\": \"{{BOOKING_ID}}\"\n}",
              "options": {
