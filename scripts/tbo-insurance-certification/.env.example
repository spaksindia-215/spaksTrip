# TBO Insurance Certification Configuration
# Copy this to client/.env.local and fill in your credentials

# ─── REQUIRED: TBO API Credentials ─────────────────────────────────────────
TBO_INSURANCE_USERNAME=your_username_here
TBO_INSURANCE_API_PASSWORD=your_password_here

# ─── OPTIONAL: API URLs (Defaults shown) ───────────────────────────────────
# TBO_BASE_URL=http://sharedapi.tektravels.com
# TBO_INSURANCE_SEARCH_URL=https://InsuranceBE.tektravels.com/InsuranceService.svc/rest/Search
# TBO_INSURANCE_BOOK_URL=https://InsuranceBE.tektravels.com/InsuranceService.svc/rest/Book
# TBO_INSURANCE_GENERATE_POLICY_URL=https://InsuranceBE.tektravels.com/InsuranceService.svc/rest/GeneratePolicy
# TBO_INSURANCE_GET_BOOKING_DETAILS_URL=https://InsuranceBE.tektravels.com/InsuranceService.svc/rest/GetBookingDetails

# ─── OPTIONAL: Server IP (Your public IP where requests originate) ──────────
# TBO_INSURANCE_SERVER_IP=1.1.1.1

# ─── OPTIONAL: Retry Configuration ──────────────────────────────────────────
# RETRY_ATTEMPTS=3                    # Number of retries for failed requests (1-10)
# RETRY_DELAY_MS=2000                # Delay between retries in milliseconds (500-10000)

# ─── OPTIONAL: Request Configuration ─────────────────────────────────────────
# REQUEST_TIMEOUT_MS=30000           # Timeout per request in milliseconds (5000-60000)
# DELAY_BETWEEN_REQUESTS_MS=2000     # Delay between sequential requests (1000-5000)

# ─── OPTIONAL: Logging & Output ──────────────────────────────────────────────
# LOG_LEVEL=info                     # Log verbosity: debug | info | warn | error
# OUTPUT_DIR=./certification-output  # Directory for test case output

# ─── OPTIONAL: Travel Configuration ──────────────────────────────────────────
# TRAVEL_START_DATE=2026-07-25T00:00:00     # Travel start date (ISO 8601)
# TRIP_DURATION_DAYS=7                       # Trip duration in days

# ═════════════════════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS:
# 1. Copy this file to: client/.env.local
# 2. Uncomment lines you want to customize
# 3. Fill in TBO_INSURANCE_USERNAME and TBO_INSURANCE_API_PASSWORD with your credentials
# 4. Run: npm run insurance-certification
# ═════════════════════════════════════════════════════════════════════════════
